# ══════════════════════════════════════════════════════════
#  Inner Root Platform — Master Environment Template
# ══════════════════════════════════════════════════════════
# Copy the relevant sections to each service's .env file

# ── Frontend (react-project/.env.local) ──────────────────
VITE_API_URL=https://your-backend.up.railway.app/api
VITE_OTP_URL=https://your-otp-service.up.railway.app
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Backend (inner-root-backend/.env) ────────────────────
DATABASE_URL=jdbc:mysql://your-host:3306/innerrootdb?useSSL=true&serverTimezone=UTC
DB_USER=your_db_user
DB_PASSWORD=your_db_password
JWT_SECRET=generate_a_256_bit_secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
ALLOWED_ORIGINS=https://your-app.vercel.app
AI_API_KEY=your_openrouter_key
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_API_MODEL=google/gemini-2.0-flash-lite-001

# ── OTP Service (otp-service/.env) ───────────────────────
PORT=3001
NODE_ENV=production
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=innerrootdb
JWT_SECRET=generate_another_256_bit_secret
SMS_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
ALLOWED_ORIGINS=https://your-app.vercel.app
