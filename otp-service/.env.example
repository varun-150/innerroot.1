# ── OTP Service Environment Variables ──
# Copy this file to .env and fill in real values

# Server
PORT=3001
NODE_ENV=production

# Database (MySQL) — use Railway/Render/PlanetScale DB credentials
DB_HOST=your-mysql-host.railway.app
DB_PORT=3306
DB_NAME=innerrootdb
DB_USER=root
DB_PASSWORD=your_password

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_REAL_SECRET
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY_DAYS=30

# OTP Delivery Provider: 'resend' (email) | 'twilio' (sms) | 'sns' (sms) | 'console' (dev)
SMS_PROVIDER=resend

# Resend (email-based OTP delivery) — https://resend.com
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_TO_EMAIL=  # Optional: override recipient (for testing)

# Twilio (SMS, if using SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# AWS SNS (SMS, if using SMS_PROVIDER=sns)
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxx
# AWS_REGION=ap-south-1

# Security — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
